# ============================================================================
# Customer Intelligence Agent — environment template
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# ============================================================================

# ---- Supabase (hosted cloud project) --------------------------------------
# Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Project Settings -> API -> JWT Settings (FastAPI verifies tokens; JWKS is used
# for asymmetric ES256/RS256 projects, this secret for legacy HS256 projects)
SUPABASE_JWT_SECRET=your-jwt-secret

# Postgres connection — use the SESSION POOLER (IPv4) so Docker containers can
# reach it. Project -> Connect -> Session pooler. URL-encode special chars in the
# password (e.g. @ -> %40). Note the postgresql+psycopg driver.
DATABASE_URL=postgresql+psycopg://postgres.YOUR-REF:YOUR-PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ---- Frontend (Next.js public vars) ---------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Same-origin proxy to FastAPI (see frontend/next.config.mjs rewrites)
NEXT_PUBLIC_API_BASE_URL=/api/backend

# ---- Ollama (local LLM runtime) -------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
LLM_PRIMARY_MODEL=qwen2.5:3b
LLM_HEAVY_MODEL=qwen2.5:3b
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# ---- Hugging Face — PRIMARY LLM (Ollama is the fallback) ------------------
HF_TOKEN=your-hf-token
HF_PRIMARY_MODEL=Qwen/Qwen2.5-72B-Instruct

# ---- Neo4j (memory graph) -------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me

# ---- Backend behaviour ----------------------------------------------------
LLM_REQUEST_TIMEOUT=60
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
